# ── Segurança (obrigatório — alterar em produção!) ──
SECRET_KEY=gera-uma-chave-aleatoria-longa-aqui
JWT_SECRET_KEY=gera-outra-chave-jwt-aleatoria-aqui

# ── Base de dados (Railway fornece automaticamente se adicionar PostgreSQL) ──
DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname

# ── SMTP — Email (opcional) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=teu@email.com
SMTP_PASSWORD=tua-password-de-aplicacao
SMTP_FROM=teu@email.com
SMTP_FROM_NAME=AgroCaua
SMTP_TLS=True
SMTP_SSL=False
